[Application]
name=org.albanicdevel.flider
runtime=org.gnome.Platform/x86_64/3.38
sdk=org.gnome.Sdk/x86_64/3.38
command=flider

[Context]
sockets=x11;wayland;
filesystems=/var/lib/flatpak;~/.local/share/flatpak;

[Session Bus Policy]
org.freedesktop.Flatpak=talk
org.albanicdevel.flider=own

[Extension org.albanicdevel.flider.Debug]
directory=lib/debug
autodelete=true
no-autodownload=true

[Build]
built-extensions=org.albanicdevel.flider.Debug;